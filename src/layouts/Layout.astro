---
import AsciiTrail from '../components/AsciiTrail';
import Logger from '../components/Logger';
import Navbar from '../components/Navbar';

interface Props {
  title?: string;
}

const { title = "Vittorio Renna" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Navbar client:load currentPath={Astro.url.pathname} />
    <AsciiTrail client:load />

    <slot />
    
    <Logger client:load />
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    background: #111;
    color: #eee;
    font-family: "Roboto", monospace;
    overflow: hidden;
  }
</style>
