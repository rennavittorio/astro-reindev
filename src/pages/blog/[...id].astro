---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import Layout from '../../layouts/Layout.astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} · vittorio renna`}>
  <main class="fixed inset-0 overflow-y-auto z-10 pt-20 pb-16 px-6">
    <div class="max-w-xl mx-auto" data-no-trail>
      <a
        href="/blog"
        class="text-[10px] tracking-widest uppercase text-white/20 hover:text-white/50 transition-colors mb-10 inline-block font-mono"
      >
        ← commits
      </a>

      <article>
        <header class="mb-10">
          <div class="text-[10px] text-white/20 mb-3 font-mono">
            {new Date(post.data.date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </div>
          <h1 class="text-xl text-white/80 font-mono font-light">{post.data.title}</h1>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {post.data.tags.map(tag => (
                <span class="text-[10px] text-white/20 border border-white/10 px-2 py-0.5 font-mono">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <div class="prose-blog">
          <Content />
        </div>
      </article>
    </div>
  </main>
</Layout>

<style is:global>
  .prose-blog {
    font-family: 'Roboto', monospace;
    font-size: 0.875rem;
    line-height: 1.8;
    color: rgba(238, 238, 238, 0.5);
  }

  .prose-blog p {
    margin-bottom: 1.25rem;
  }

  .prose-blog h1,
  .prose-blog h2,
  .prose-blog h3,
  .prose-blog h4 {
    color: rgba(238, 238, 238, 0.8);
    font-weight: 400;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose-blog h2 { font-size: 1rem; letter-spacing: 0.05em; }
  .prose-blog h3 { font-size: 0.875rem; letter-spacing: 0.03em; }

  .prose-blog code {
    background: rgba(238, 238, 238, 0.06);
    padding: 0.15em 0.4em;
    font-size: 0.8em;
    color: rgba(238, 238, 238, 0.65);
  }

  .prose-blog pre {
    background: rgba(238, 238, 238, 0.04);
    border: 1px solid rgba(238, 238, 238, 0.08);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose-blog pre code {
    background: none;
    padding: 0;
    font-size: 0.8rem;
    color: rgba(238, 238, 238, 0.55);
  }

  .prose-blog ul,
  .prose-blog ol {
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .prose-blog li {
    margin-bottom: 0.3rem;
  }

  .prose-blog a {
    color: rgba(238, 238, 238, 0.6);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(238, 238, 238, 0.2);
  }

  .prose-blog a:hover {
    color: rgba(238, 238, 238, 0.9);
    text-decoration-color: rgba(238, 238, 238, 0.5);
  }

  .prose-blog blockquote {
    border-left: 1px solid rgba(238, 238, 238, 0.12);
    padding-left: 1rem;
    color: rgba(238, 238, 238, 0.3);
    margin: 1.5rem 0;
    font-style: italic;
  }

  .prose-blog hr {
    border: none;
    border-top: 1px solid rgba(238, 238, 238, 0.08);
    margin: 2rem 0;
  }
</style>
