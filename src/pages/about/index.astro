---
import Layout from "../../layouts/Layout.astro";
import CtaLink from "../../components/CtaLink.astro";
---

<Layout>
  <main class="fixed inset-0 flex flex-col gap-16 items-center justify-center z-10 pointer-events-none select-none px-4 text-center text-sm">
    <div>
      <p class="p-2 bg-dark">I'm Vittorio Renna, fullstack developer specilized in Next, React, Typescript, Ruby on Rails and PostgreSQL.</p>
      <p class="p-2 bg-dark">I also have an accademic background in Neuroscience and a previuos experience as an IT Project Manager, means I understand both code and context, building what matters.</p>
    </div>
    <div class="flex flex-col gap-4 items-center justify-center">
      <div class="flex flex-col sm:flex-row items-center">
        <span class="px-2 sm:py-2 bg-dark">wanna know more about me?</span>
        <CtaLink href="/rv-cv.pdf" label="resume.pdf" download />
      </div>
      <div class="flex flex-col sm:flex-row items-center">
        <span class="px-2 sm:py-2 bg-dark">see my projects?</span>
        <CtaLink href="https://github.com/rennavittorio" label="github" />
      </div>
    </div>
  </main>
</Layout>
