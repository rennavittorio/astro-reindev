---
import Layout from "../../layouts/Layout.astro";
import CtaLink from "../../components/CtaLink.astro";
---

<Layout>
  <main class="fixed w-full sm:w-125 left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 flex flex-col gap-8 items-center justify-center z-10 pointer-events-none select-none px-4 text-center text-sm">
    <div>
      <p class="p-2 bg-dark">fullstack developer. <br> next, react, typescript, rails, postgresql.</p>
      <p class="p-2 bg-dark">neuroscience background. <br> i build websites and apps with people in mind.</p>
    </div>
    <div class="flex flex-col gap-4 items-center justify-center">
      <div class="flex flex-col sm:flex-row items-center">
        <span class="px-2 sm:py-2 bg-dark">want my resume?</span>
        <CtaLink href="/rv-cv.pdf" label="resume.pdf" download />
      </div>
      <div class="flex flex-col sm:flex-row items-center">
        <span class="px-2 sm:py-2 bg-dark">see my projects?</span>
        <CtaLink href="https://github.com/rennavittorio" label="github" />
      </div>
    </div>
  </main>
</Layout>
